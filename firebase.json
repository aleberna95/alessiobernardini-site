{
  "hosting": {
    "public": "site/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/qr",
        "destination": "https://alessiobernardini.dev/",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|wasm|data)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      }
    ]
  }
}
